{
  "enabled": true,
  "config-item-title": "Exclude destination-automation journald (duplicates)",
  "send-to-storage": false,
  "matchers": [
    {
      "attribute": "journald.unit",
      "operator": "MATCHES",
      "values": ["user@1001.service"]
    },
    {
      "attribute": "log.source.origin",
      "operator": "MATCHES",
      "values": ["JOURNALD_LOG_DETECTOR"]
    }
  ]
}
